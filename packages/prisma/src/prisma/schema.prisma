generator client {
  provider            = "prisma-client"
  output              = "./generated"
  moduleFormat        = "cjs"
  importFileExtension = "ts"
  previewFeatures     = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

model FCMToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  users     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("FCMTokens")
}

model Friendship {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  friendId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  friend    User     @relation("Friendships_friendIdToUsers", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("Friendships_userIdToUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId], map: "Friendships_userId_friendId_uk")
  @@index([friendId], map: "friendships_friend_id")
  @@map("Friendships")
}

model Image {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String?            @db.Uuid
  location      String             @db.VarChar(255)
  key           String             @db.VarChar(255)
  json          Json
  createdAt     DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(6)
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  recipeImages  RecipeImage[]
  profileImages UserProfileImage[]
  discoverRecipeImages DiscoverRecipeImage[]

  @@index([userId], map: "images_user_id")
  @@map("Images")
}

model Label {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  labelGroupId String?       @db.Uuid
  title        String        @db.VarChar(255)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  labelGroup   LabelGroup?   @relation(fields: [labelGroupId], references: [id], onDelete: SetNull)
  profileItems ProfileItem[]
  recipeLabels RecipeLabel[]

  @@unique([userId, title], map: "Labels_userId_title_uk")
  @@index([userId], map: "labels_user_id")
  @@index([labelGroupId], map: "labels_label_group_id")
  @@map("Labels")
}

model LabelGroup {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  title              String   @db.VarChar(255)
  warnWhenNotPresent Boolean
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @db.Timestamptz(6)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  labels             Label[]

  @@unique([userId, title], map: "LabelGroups_userId_title_uk")
  @@index([userId], map: "labelgroups_user_id")
  @@map("LabelGroups")
}

model MealPlanItem {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @db.Uuid
  mealPlanId        String             @db.Uuid
  recipeId          String?            @db.Uuid
  title             String
  notes             String             @default("")
  scheduledDate     DateTime           @db.Date
  scheduled         DateTime?          @db.Timestamptz(6)
  meal              String             @db.VarChar(255)
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)
  mealPlan          MealPlan           @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe            Recipe?            @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingListItems ShoppingListItem[]

  @@index([mealPlanId], map: "meal_plan_items_meal_plan_id")
  @@index([recipeId], map: "meal_plan_items_recipe_id")
  @@map("MealPlanItems")
}

model MealPlanCollaborator {
  id         String   @id @default(uuid()) @db.Uuid
  mealPlanId String   @db.Uuid
  userId     String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mealPlanId, userId])
  @@map("MealPlan_Collaborators")
}

model MealPlan {
  id                String                 @id @default(uuid()) @db.Uuid
  userId            String                 @db.Uuid
  title             String
  customMealOptions String?
  createdAt         DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @db.Timestamptz(6)
  items             MealPlanItem[]
  collaboratorUsers MealPlanCollaborator[]
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("MealPlans")
}

model Message {
  id               String   @id @default(uuid()) @db.Uuid
  fromUserId       String   @db.Uuid
  toUserId         String   @db.Uuid
  recipeId         String?  @db.Uuid
  originalRecipeId String?  @db.Uuid
  body             String?
  type             String?  @db.VarChar(255)
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)
  fromUser         User     @relation("Messages_fromUserIdToUsers", fields: [fromUserId], references: [id], onDelete: Cascade)
  originalRecipe   Recipe?  @relation("Messages_originalRecipeIdToRecipes", fields: [originalRecipeId], references: [id])
  recipe           Recipe?  @relation("Messages_recipeIdToRecipes", fields: [recipeId], references: [id])
  toUser           User     @relation("Messages_toUserIdToUsers", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([originalRecipeId], map: "messages_original_recipe_id")
  @@index([recipeId], map: "messages_recipe_id")
  @@index([fromUserId, createdAt], map: "messages_from_user_id_created_at")
  @@index([toUserId, createdAt], map: "messages_to_user_id_created_at")
  @@map("Messages")
}

model AssistantMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  role      String   @db.VarChar(255)
  content   String?
  name      String?
  json      Json
  version   Int
  recipeId  String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  user      User     @relation("AssistantMessages_userIdToUsers", fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe?  @relation("AssistantMessages_recipeIdToRecipes", fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("AssistantMessages")
}

model UserCreditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  operation String   @db.VarChar(64)
  credits   Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "user_credit_logs_user_id_created_at")
  @@map("UserCreditLogs")
}

model ProfileItem {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  recipeId   String?  @db.Uuid
  labelId    String?  @db.Uuid
  title      String   @db.VarChar(255)
  type       String   @db.VarChar(255)
  visibility String   @db.VarChar(255)
  order      Int
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  label      Label?   @relation(fields: [labelId], references: [id], onDelete: Cascade)
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "profile_item_user_id")
  @@map("ProfileItems")
}

model RecipeImage {
  id        String   @id @default(uuid()) @db.Uuid
  recipeId  String   @db.Uuid
  imageId   String   @db.Uuid
  order     Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId], map: "recipe__images_recipe_id")
  @@index([imageId], map: "recipe__images_image_id")
  @@map("Recipe_Images")
}

model RecipeLabel {
  id        String   @id @default(uuid()) @db.Uuid
  recipeId  String   @db.Uuid
  labelId   String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([labelId, recipeId], map: "Recipe_Labels_labelId_recipeId_uk")
  @@unique([recipeId, labelId])
  @@index([labelId], map: "recipe__labels_label_id")
  @@index([recipeId], map: "recipe__labels_recipe_id")
  @@map("Recipe_Labels")
}

model RecipeLink {
  id             String   @id @default(uuid()) @db.Uuid
  recipeId       String   @db.Uuid
  linkedRecipeId String   @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)
  recipe         Recipe   @relation("RecipeLinks_recipeId", fields: [recipeId], references: [id], onDelete: Cascade)
  linkedRecipe   Recipe   @relation("RecipeLinks_linkedRecipeId", fields: [linkedRecipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, linkedRecipeId])
  @@index([recipeId])
  @@index([linkedRecipeId])
  @@map("RecipeLinks")
}

model Recipe {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @db.Uuid
  fromUserId        String?            @db.Uuid
  title             String             @db.VarChar(255)
  description       String             @default("")
  yield             String             @default("")
  activeTime        String             @default("")
  totalTime         String             @default("")
  source            String             @default("")
  url               String             @default("")
  notes             String             @default("")
  ingredients       String             @default("")
  instructions      String             @default("")
  folder            String             @db.VarChar(255)
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)
  indexedAt         DateTime?          @db.Timestamptz(6)
  lastMadeAt        DateTime?          @db.Date
  rating            Int?
  nutritionServingSize         String?
  nutritionCalories            Float?
  nutritionTotalFat            Float?
  nutritionSaturatedFat        Float?
  nutritionTransFat            Float?
  nutritionPolyunsaturatedFat  Float?
  nutritionMonounsaturatedFat  Float?
  nutritionCholesterol         Float?
  nutritionSodium              Float?
  nutritionTotalCarbs          Float?
  nutritionDietaryFiber        Float?
  nutritionTotalSugars         Float?
  nutritionAddedSugars         Float?
  nutritionProtein             Float?
  nutritionVitaminD            Float?
  nutritionCalcium             Float?
  nutritionIron                Float?
  nutritionPotassium           Float?
  nutritionOtherDetails        String?
  mealPlanItems     MealPlanItem[]
  originalRecipe    Message[]          @relation("Messages_originalRecipeIdToRecipes")
  messages          Message[]          @relation("Messages_recipeIdToRecipes")
  assistantMessages AssistantMessage[] @relation("AssistantMessages_recipeIdToRecipes")
  profileItems      ProfileItem[]
  recipeImages      RecipeImage[]
  recipeLabels      RecipeLabel[]
  recipeLinks       RecipeLink[]       @relation("RecipeLinks_recipeId")
  linkedByRecipes   RecipeLink[]       @relation("RecipeLinks_linkedRecipeId")
  fromUser          User?              @relation("Recipes_fromUserIdToUsers", fields: [fromUserId], references: [id])
  user              User               @relation("Recipes_userIdToUsers", fields: [userId], references: [id], onDelete: Cascade)
  shoppingListItems ShoppingListItem[]
  discoverRecipes   DiscoverRecipe[]
  discoverRecipeSave DiscoverRecipeSave?
  tsv               Unsupported("tsvector")?

  @@index([userId], map: "recipes_user_id")
  @@index([fromUserId], map: "recipes_from_user_id")
  @@index([userId, folder, createdAt(sort: Desc)], map: "recipes_user_folder_created_at")
  @@index([userId, folder, title], map: "recipes_user_folder_title")
  @@index([tsv], type: Gin, map: "recipes_tsv_idx")
  @@map("Recipes")
}

model DiscoverRecipe {
  id             String                @id @default(uuid()) @db.Uuid
  authorId       String                @db.Uuid
  sourceRecipeId String?               @db.Uuid
  title          String                @db.VarChar(255)
  description    String                @default("")
  yield          String                @default("")
  activeTime     String                @default("")
  totalTime      String                @default("")
  notes          String                @default("")
  ingredients    String                @default("")
  instructions   String                @default("")
  language       String                @db.VarChar(35)
  categories     String[]              @default([])
  approvalState  DiscoverApprovalState @default(PENDING)
  ratingAverage  Float                 @default(0)
  ratingCount    Int                   @default(0)
  saveCount      Int                   @default(0)
  rankScore      Float                 @default(0)
  tosAgreedAt    DateTime              @db.Timestamptz(6)
  tosVersion     String                @db.VarChar(255)
  nutritionServingSize         String?
  nutritionCalories            Float?
  nutritionTotalFat            Float?
  nutritionSaturatedFat        Float?
  nutritionTransFat            Float?
  nutritionPolyunsaturatedFat  Float?
  nutritionMonounsaturatedFat  Float?
  nutritionCholesterol         Float?
  nutritionSodium              Float?
  nutritionTotalCarbs          Float?
  nutritionDietaryFiber        Float?
  nutritionTotalSugars         Float?
  nutritionAddedSugars         Float?
  nutritionProtein             Float?
  nutritionVitaminD            Float?
  nutritionCalcium             Float?
  nutritionIron                Float?
  nutritionPotassium           Float?
  nutritionOtherDetails        String?
  modifiedAt     DateTime?             @db.Timestamptz(6)
  deletedAt      DateTime?             @db.Timestamptz(6)
  createdAt      DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(6)
  author         User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sourceRecipe   Recipe?               @relation(fields: [sourceRecipeId], references: [id], onDelete: SetNull)
  discoverRecipeImages DiscoverRecipeImage[]
  ratings        DiscoverRecipeRating[]
  saves          DiscoverRecipeSave[]
  reports        DiscoverRecipeReport[]
  discoverRecipeLinks     DiscoverRecipeLink[] @relation("DiscoverRecipeLinks_discoverRecipeId")
  linkedByDiscoverRecipes DiscoverRecipeLink[] @relation("DiscoverRecipeLinks_linkedDiscoverRecipeId")
  tsv            Unsupported("tsvector")?

  @@index([authorId, createdAt(sort: Desc)], map: "discover_recipes_author_id_created_at")
  @@index([approvalState, rankScore(sort: Desc), createdAt(sort: Desc)], map: "discover_recipes_approval_state_rank_score")
  @@index([approvalState, createdAt(sort: Desc)], map: "discover_recipes_approval_state_created_at")
  @@index([approvalState, saveCount(sort: Desc), createdAt(sort: Desc)], map: "discover_recipes_approval_state_save_count")
  @@index([approvalState, ratingAverage(sort: Desc), ratingCount(sort: Desc)], map: "discover_recipes_approval_state_rating")
  @@index([language], map: "discover_recipes_language")
  @@index([categories], type: Gin, map: "discover_recipes_categories_idx")
  @@index([tsv], type: Gin, map: "discover_recipes_tsv_idx")
  @@map("Discover_Recipes")
}

model DiscoverRecipeLink {
  id                     String         @id @default(uuid()) @db.Uuid
  discoverRecipeId       String         @db.Uuid
  linkedDiscoverRecipeId String         @db.Uuid
  createdAt              DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime       @updatedAt @db.Timestamptz(6)
  discoverRecipe         DiscoverRecipe @relation("DiscoverRecipeLinks_discoverRecipeId", fields: [discoverRecipeId], references: [id], onDelete: Cascade)
  linkedDiscoverRecipe   DiscoverRecipe @relation("DiscoverRecipeLinks_linkedDiscoverRecipeId", fields: [linkedDiscoverRecipeId], references: [id], onDelete: Cascade)

  @@unique([discoverRecipeId, linkedDiscoverRecipeId], map: "discover_recipe_links_pair_uk")
  @@index([discoverRecipeId], map: "discover_recipe_links_discover_recipe_id")
  @@index([linkedDiscoverRecipeId], map: "discover_recipe_links_linked_discover_recipe_id")
  @@map("Discover_Recipe_Links")
}

model DiscoverRecipeImage {
  id               String         @id @default(uuid()) @db.Uuid
  discoverRecipeId String         @db.Uuid
  imageId          String         @db.Uuid
  order            Int
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)
  discoverRecipe   DiscoverRecipe @relation(fields: [discoverRecipeId], references: [id], onDelete: Cascade)
  image            Image          @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([discoverRecipeId], map: "discover_recipe__images_discover_recipe_id")
  @@index([imageId], map: "discover_recipe__images_image_id")
  @@map("Discover_Recipe_Images")
}

model DiscoverRecipeRating {
  id               String         @id @default(uuid()) @db.Uuid
  discoverRecipeId String         @db.Uuid
  userId           String         @db.Uuid
  rating           Int
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)
  discoverRecipe   DiscoverRecipe @relation(fields: [discoverRecipeId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discoverRecipeId, userId], map: "Discover_Recipe_Ratings_discoverRecipeId_userId_uk")
  @@index([userId], map: "discover_recipe__ratings_user_id")
  @@map("Discover_Recipe_Ratings")
}

model DiscoverRecipeSave {
  id               String         @id @default(uuid()) @db.Uuid
  discoverRecipeId String         @db.Uuid
  userId           String         @db.Uuid
  recipeId         String?        @unique(map: "Discover_Recipe_Saves_recipeId_uk") @db.Uuid
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)
  discoverRecipe   DiscoverRecipe @relation(fields: [discoverRecipeId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe           Recipe?        @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, discoverRecipeId], map: "discover_recipe__saves_user_id_discover_recipe_id")
  @@map("Discover_Recipe_Saves")
}

model DiscoverRecipeReport {
  id               String                 @id @default(uuid()) @db.Uuid
  discoverRecipeId String                 @db.Uuid
  source           DiscoverReportSource
  reporterId       String?                @db.Uuid
  reason           String
  status           DiscoverReportStatus   @default(OPEN)
  createdAt        DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @db.Timestamptz(6)
  discoverRecipe   DiscoverRecipe         @relation(fields: [discoverRecipeId], references: [id], onDelete: Cascade)
  reporter         User?                  @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@unique([discoverRecipeId, reporterId], map: "Discover_Recipe_Reports_discoverRecipeId_reporterId_uk")
  @@index([status, createdAt], map: "discover_recipe__reports_status_created_at")
  @@index([discoverRecipeId], map: "discover_recipe__reports_discover_recipe_id")
  @@map("Discover_Recipe_Reports")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expires   DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("Sessions")
}

model ShoppingListItem {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  shoppingListId String        @db.Uuid
  mealPlanItemId String?       @db.Uuid
  recipeId       String?       @db.Uuid
  title          String
  completed      Boolean
  categoryTitle  String?
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)
  mealPlanItem   MealPlanItem? @relation(fields: [mealPlanItemId], references: [id], onDelete: Cascade)
  recipe         Recipe?       @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  shoppingList   ShoppingList  @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipeId], map: "shopping_list_items_recipe_id")
  @@index([mealPlanItemId], map: "shopping_list_items_meal_plan_item_id")
  @@index([shoppingListId], map: "shopping_list_items_shopping_list_id")
  @@map("ShoppingListItems")
}

model ShoppingListCollaborator {
  id             String       @id @default(uuid()) @db.Uuid
  shoppingListId String       @db.Uuid
  userId         String       @db.Uuid
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shoppingListId, userId])
  @@map("ShoppingList_Collaborators")
}

model ShoppingList {
  id                String                     @id @default(uuid()) @db.Uuid
  userId            String                     @db.Uuid
  title             String
  categoryOrder     String?
  createdAt         DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime                   @updatedAt @db.Timestamptz(6)
  items             ShoppingListItem[]
  collaboratorUsers ShoppingListCollaborator[]
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ShoppingLists")
}

model StripeEvent {
  id        String   @id @default(uuid()) @db.Uuid
  stripeId  String   @unique @db.VarChar(255)
  userId    String?  @db.Uuid
  blob      Json
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("StripeEvents")
}

model StripePayment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @db.Uuid
  amountPaid      Int
  customerId      String   @db.VarChar(255)
  customerEmail   String?  @db.VarChar(255)
  paymentIntentId String?  @unique @db.VarChar(255)
  subscriptionId  String?  @db.VarChar(255)
  invoiceBlob     Json
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("StripePayments")
}

model UserSubscription {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  name      String    @db.VarChar(255)
  expires   DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserSubscriptions")
}

model UserProfileImage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  imageId   String   @db.Uuid
  order     Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("User_Profile_Images")
}

model User {
  id                        String                     @id @default(uuid()) @db.Uuid
  name                      String
  email                     String                     @unique(map: "Users_email_uk")
  passwordHash              String?
  passwordSalt              String?
  passwordVersion           Int?
  lastLogin                 DateTime?                  @db.Timestamptz(6)
  createdAt                 DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @db.Timestamptz(6)
  stripeCustomerId          String?                    @unique @db.VarChar(255)
  handle                    String?                    @unique(map: "Users_handle_uk") @db.VarChar(255)
  enableProfile             Boolean                    @default(false)
  profileVisibility         String?                    @db.VarChar(255)
  discoverStanding          UserDiscoverStanding       @default(NORMAL)
  preferences               Json?
  fcmTokens                 FCMToken[]
  incomingFriendships       Friendship[]               @relation("Friendships_friendIdToUsers")
  outgoingFriendships       Friendship[]               @relation("Friendships_userIdToUsers")
  images                    Image[]
  labels                    Label[]
  labelGroups               LabelGroup[]
  mealPlanItems             MealPlanItem[]
  mealPlanCollaborators     MealPlanCollaborator[]
  mealPlans                 MealPlan[]
  incomingMessages          Message[]                  @relation("Messages_fromUserIdToUsers")
  outgoingMessages          Message[]                  @relation("Messages_toUserIdToUsers")
  assistantMessages         AssistantMessage[]         @relation("AssistantMessages_userIdToUsers")
  profileItems              ProfileItem[]
  outgoingRecipes           Recipe[]                   @relation("Recipes_fromUserIdToUsers")
  recipes                   Recipe[]                   @relation("Recipes_userIdToUsers")
  sessions                  Session[]
  shoppingListItems         ShoppingListItem[]
  shoppingListCollaborators ShoppingListCollaborator[]
  shoppingLists             ShoppingList[]
  stripePayments            StripePayment[]
  subscriptions             UserSubscription[]
  profileImages             UserProfileImage[]
  jobs                      Job[]
  stripeEvents              StripeEvent[]
  creditLogs                UserCreditLog[]
  discoverRecipes           DiscoverRecipe[]
  discoverRecipeRatings     DiscoverRecipeRating[]
  discoverRecipeSaves       DiscoverRecipeSave[]
  discoverRecipeReports     DiscoverRecipeReport[]

  @@map("Users")
}

model ClipCache {
  id          String   @id @default(uuid()) @db.Uuid
  url         String
  urlHash     Bytes    @unique
  recipe      Json
  clipVersion Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@map("ClipCache")
}

model SequelizeMeta {
  name String @id @db.VarChar(255)
}

model Job {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  type       JobType
  status     JobStatus
  progress   Int
  resultCode Int?
  meta       Json?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum JobType {
  IMPORT
  EXPORT
  COOKBOOK
}

enum JobStatus {
  CREATE
  RUN
  FAIL
  SUCCESS
}

enum DiscoverApprovalState {
  PENDING
  ACTIVE
  SHADOWBANNED
}

enum UserDiscoverStanding {
  NORMAL
  TRUSTED
  SHADOWBANNED
}

enum DiscoverReportSource {
  USER
  SYSTEM
}

enum DiscoverReportStatus {
  OPEN
  ACTIONED
  DISMISSED
}
