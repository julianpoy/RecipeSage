{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/frontend/src",
  "projectType": "application",
  "targets": {
    "ng": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "command": "ng"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "webpack -c sw-webpack.config.js --watch",
          "webpack -c sw-webpack.config.js && ng serve --host 0.0.0.0 --disable-host-check --no-live-reload --port 8100"
        ],
        "parallel": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["util-shared:build"],
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "ng build --configuration=production --define=APP_VERSION=\"\\\"${APP_VERSION:-development}\\\"\"",
          "webpack -c sw-webpack.config.js",
          "workbox injectManifest",
          "tsx upload-sourcemaps.ts"
        ],
        "parallel": false
      }
    },
    "serve:ssr": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/frontend",
        "command": "node www/server/server.mjs"
      }
    },
    "build:selfhost": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "webpack -c sw-webpack.config.js",
          "ng build --configuration=selfhost --define=APP_VERSION=\"\\\"${APP_VERSION:-development}\\\"\"",
          "workbox injectManifest"
        ],
        "parallel": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "command": "tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "ng lint",
          "npx --yes @julianpoy/ngx-translate-lint --config ./ngx-translate-lint.config.json"
        ]
      }
    }
  }
}
