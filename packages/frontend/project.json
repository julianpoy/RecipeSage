{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/frontend/src",
  "projectType": "application",
  "targets": {
    "ng": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "command": "ng"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "tsx build-service-worker.ts --watch",
          "tsx build-service-worker.ts && ng serve --host 0.0.0.0 --no-live-reload --port 8100 --serve-path=/app/"
        ],
        "parallel": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["util-shared:build"],
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "ng build --configuration=production",
          "tsx build-service-worker.ts",
          "workbox injectManifest",
          "tsx upload-sourcemaps.ts"
        ],
        "parallel": false
      }
    },
    "build:selfhost": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "tsx build-service-worker.ts",
          "ng build --configuration=selfhost",
          "workbox injectManifest"
        ],
        "parallel": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "command": "tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/frontend",
        "commands": [
          "ng lint",
          "pnpm dlx @julianpoy/ngx-translate-lint --config ./ngx-translate-lint.config.json"
        ]
      }
    }
  }
}
