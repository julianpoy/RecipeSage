{
  "name": "express",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/express/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/express",
        "commands": [
          "tsc --project tsconfig.lib.json --noEmit",
          "tsc --project tsconfig.spec.json --noEmit"
        ],
        "parallel": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "maxWarnings": 0
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/express"
      }
    }
  }
}
